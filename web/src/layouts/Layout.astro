---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Compare grocery prices across Keells, Glomark & Cargills in Sri Lanka" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-lg font-bold text-gray-900 dark:text-white hover:text-green-600 dark:hover:text-green-400 transition-colors">
          SL Grocery Compare
        </a>
        <div class="flex items-center gap-4">
          <a
            href="/meat"
            class:list={["text-sm font-medium transition-colors", Astro.url.pathname === '/meat' ? 'text-red-600 dark:text-red-400' : 'text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400']}
          >
            Meat
          </a>
          <a
            href="/seafood"
            class:list={["text-sm font-medium transition-colors", Astro.url.pathname === '/seafood' ? 'text-blue-600 dark:text-blue-400' : 'text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400']}
          >
            Seafood
          </a>
          <a
            href="/vegetables"
            class:list={["text-sm font-medium transition-colors", Astro.url.pathname === '/vegetables' ? 'text-green-600 dark:text-green-400' : 'text-gray-600 dark:text-gray-300 hover:text-green-600 dark:hover:text-green-400']}
          >
            Vegetables
          </a>
          <a
            href="/fruits"
            class:list={["text-sm font-medium transition-colors", Astro.url.pathname === '/fruits' ? 'text-orange-600 dark:text-orange-400' : 'text-gray-600 dark:text-gray-300 hover:text-orange-600 dark:hover:text-orange-400']}
          >
            Fruits
          </a>
        </div>
      </div>
    </nav>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-gray-200 dark:border-gray-800 py-6 mt-12">
      <div class="max-w-6xl mx-auto px-4 text-center text-sm text-gray-500 dark:text-gray-400">
        Sri Lanka Grocery Price Compare — Data sourced from Keells, Glomark & Cargills online stores
      </div>
    </footer>
  </body>
</html>
